# AI Log Monitor - Server Secrets
# EDIT before real use.

# Dashboard login.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me-now

# Protects management API and signs dashboard sessions.
ADMIN_TOKEN=change-this-admin-token

# Used by new agents during first registration.
ENROLL_TOKEN=change-this-install-token

# Require X-Agent-Token on /api/ingest after agent registration.
ENFORCE_AGENT_TOKEN=true

# Delete old events/incidents on server startup. Set 0 to disable.
RETENTION_DAYS=30

# Used when server/ai.yaml sets ai.mode: "api".
AI_API_ENDPOINT=
AI_API_MODEL=
AI_API_KEY=
